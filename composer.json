{
    "name": "vanere/icalendar",
    "description": "A modern, strongly-typed, immutable iCalendar (RFC 5545 / 7986 / 5546) library for PHP.",
    "type": "library",
    "license": "MIT",
    "keywords": ["icalendar", "ical", "ics", "rfc5545", "rfc7986", "rfc5546", "calendar", "vevent"],
    "homepage": "https://github.com/vanere/icalendar",
    "support": {
        "issues": "https://github.com/vanere/icalendar/issues",
        "source": "https://github.com/vanere/icalendar"
    },
    "authors": [
        {
            "name": "vanere",
            "homepage": "https://github.com/vanere"
        }
    ],
    "require": {
        "php": ">=8.3",
        "rlanvin/php-rrule": "^2.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Vanere\\ICalendar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vanere\\ICalendar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
