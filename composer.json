{
    "name": "erenav/icalendar",
    "description": "A modern, strongly-typed, immutable iCalendar (RFC 5545 / 7986 / 5546) library for PHP.",
    "type": "library",
    "license": "MIT",
    "keywords": ["icalendar", "ical", "ics", "rfc5545", "rfc7986", "rfc5546", "calendar", "vevent"],
    "homepage": "https://github.com/erenav/icalendar",
    "support": {
        "issues": "https://github.com/erenav/icalendar/issues",
        "source": "https://github.com/erenav/icalendar"
    },
    "authors": [
        {
            "name": "erenav",
            "homepage": "https://github.com/erenav"
        }
    ],
    "require": {
        "php": ">=8.3",
        "rlanvin/php-rrule": "^2.6"
    },
    "require-dev": {
        "laravel/pint": "^1.18",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Erenav\\ICalendar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Erenav\\ICalendar\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "format": "pint",
        "lint": "pint --test",
        "check": [
            "@lint",
            "@analyse",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
